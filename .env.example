# ── Core ──────────────────────────────────────────────────────────────────────
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/trialwhisperer

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── First Owner Account (auto-created on first startup) ───────────────────────
INITIAL_OWNER_EMAIL=admin@yourdomain.com
INITIAL_OWNER_PASSWORD=change-me
INITIAL_OWNER_DOMAIN=yourdomain.com

# ── OpenClaw LLM Gateway ──────────────────────────────────────────────────────
# OpenClaw runs locally and provides Claude access — no separate API key needed
# Get token from: cat ~/.openclaw/openclaw.json | python3 -c "import json,sys; c=json.load(sys.stdin); print(c['gateway']['auth']['token'])"
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
LLM_MODEL=anthropic/claude-haiku-4-5
QA_MODEL=anthropic/claude-sonnet-4-6

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
APP_VERSION=1.0.0
UPLOADS_DIR=./uploads
