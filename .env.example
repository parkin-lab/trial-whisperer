# ── Core ──────────────────────────────────────────────────────────────────────
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/trialwhisperer

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── First Owner Account (auto-created on first startup) ───────────────────────
INITIAL_OWNER_EMAIL=admin@yourdomain.com
INITIAL_OWNER_PASSWORD=change-me
INITIAL_OWNER_DOMAIN=yourdomain.com

# ── AI (optional — LLM features disabled without these) ───────────────────────
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
LLM_MODEL=claude-haiku-4-5
QA_MODEL=claude-sonnet-4-5

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
APP_VERSION=1.0.0
UPLOADS_DIR=./uploads
