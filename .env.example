# App
# REQUIRED: generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:5173
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/trialwhisperer

# Redis
REDIS_URL=redis://redis:6379

# Email (optional - logs to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# OpenAI (optional - LLM features disabled if not set)
OPENAI_API_KEY=
QA_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# First owner account (created on startup if no users exist)
INITIAL_OWNER_EMAIL=
INITIAL_OWNER_PASSWORD=
INITIAL_OWNER_DOMAIN=adventhealth.com
